@model IEnumerable<MegaQr.Web.Models.DTOs.SectionDto>

@{
    ViewData["Title"] = "Section Üret";
}

<h2>Bölüm Oluştur</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="CreateSectionPost" method="post">
    <button type="submit" class="btn btn-primary">Bölüm Üret</button>
</form>

<hr />

<h3>Mevcut Bölümler</h3>
<ul>
    @foreach (var sec in Model)
    {
        <li>@sec.SectionName</li>
    }
</ul>
